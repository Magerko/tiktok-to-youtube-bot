# Telegram
TELEGRAM_BOT_TOKEN=123456789:ABC-DEF...
ADMIN_USERS=123456789

# Интервал опроса TikTok-аккаунтов, секунд
CHECK_INTERVAL=600

# Папки
DATA_FOLDER=pydata
DOWNLOAD_FOLDER=downloads
SECRETS_FOLDER=secrets

# OPTIONAL fallback: общий client_secrets.json для всех каналов сразу.
# Если задан и файл существует, при подключении канала появится опция «🔁 Использовать общий».
# Рекомендуется НЕ задавать и грузить отдельный client_secrets для каждого канала
# (тогда у каждого канала своя квота 10 000 ед./сутки).
# YOUTUBE_CLIENT_SECRETS=secrets/client_secrets.json

# Параметры заливки на YouTube
YT_PRIVACY=public
YT_CATEGORY_ID=22
YT_DEFAULT_LANGUAGE=ru
YT_MADE_FOR_KIDS=false

# Опциональный Redis для FSM-состояний (выживут перезапуск)
# REDIS_URL=redis://localhost:6379/0
